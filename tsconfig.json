{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "output/private/build",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "output", "test"]
}
