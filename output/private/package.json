{
  "name": "xhs-field-shortcut",
  "version": "1.0.0",
  "description": "Feishu Base field shortcut for Xiaohongshu publish QR",
  "main": "output/private/build/index.js",
  "scripts": {
    "start": "node ./scripts/start-with-debug-auth.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pack": "node ./scripts/pack-with-readme.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "unit": "node -r ts-node/register/transpile-only test/index.test.ts",
    "test": "npm run check && npm run unit"
  },
  "dependencies": {
    "@lark-opdev/block-basekit-server-api": "1.0.6"
  },
  "devDependencies": {
    "@lark-opdev/block-basekit-cli": "1.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
